{
  "name": "react-native-formik-helper",
  "version": "0.2.1",
  "description": "Formik helper components for React Native",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-formik-helper-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest --passWithNoTests",
    "postinstall": "del-cli node_modules/@types/hoist-non-react-statics/node_modules/@types/react node_modules/react-native/node_modules/@types/react"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "formik",
    "form",
    "helper"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junocs/react-native-formik-helper.git"
  },
  "author": "Juno Sheridan <juno.sheridan@gmail.com> (https://github.com/junocs)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/junocs/react-native-formik-helper/issues"
  },
  "homepage": "https://github.com/junocs/react-native-formik-helper#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.0.0",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/eslint-config": "0.85.1",
    "@react-native/jest-preset": "0.85.1",
    "@types/react": "^19.1.1",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "formik": "^2.4.9",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "react": "19.2.0",
    "react-native": "0.85.1",
    "react-native-builder-bob": "^0.41.0",
    "turbo": "^2.8.21",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "formik": "*",
    "react": "*",
    "react-native": "*"
  },
  "resolutions": {
    "@types/react": "19.1.1",
    "@types/hoist-non-react-statics/@types/react": "19.1.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/typescript-estree": "^8.58.2"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "bracketSpacing": true,
    "semi": false,
    "printWidth": 120
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook"
    ],
    "version": "0.62.0"
  }
}
